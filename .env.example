# Copy this file to `.env` at the project root and fill in your key:
#   cp .env.example .env
#
# simula reads keys ONLY from a `.env` file at the project root (via dotenv_values).
# A shell-exported variable is deliberately ignored. `.env` is gitignored; never commit it.
#
# The variable name must match `provider.api_key_env` in your run's YAML config.
# All bundled examples use OPENROUTER_API_KEY:
OPENROUTER_API_KEY=sk-or-...

# Using a different OpenAI-compatible provider? Set api_key_env in the config to match,
# and add that variable here, e.g.:
# OPENAI_API_KEY=sk-...
